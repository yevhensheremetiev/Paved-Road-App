{
  "name": "paved-road-app",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --recursive --parallel --if-present dev",
    "build": "pnpm --recursive --if-present build",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "tsc --build --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:reset": "pnpm --filter @paved-road/database db:reset",
    "db:seed": "pnpm --filter @paved-road/database db:seed",
    "prisma:generate": "pnpm --filter @paved-road/database prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @paved-road/database prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @paved-road/database prisma:migrate:deploy",
    "prisma:validate": "pnpm --filter @paved-road/database prisma:validate",
    "verify": "pnpm format:check && pnpm lint && pnpm prisma:generate && pnpm typecheck && pnpm prisma:validate && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "prisma": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
