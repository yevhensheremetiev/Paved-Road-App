{
  "name": "@paved-road/database",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://paved_road:paved_road@localhost:5432/paved_road_dev?schema=public}\" prisma generate --config prisma.config.ts",
    "prisma:validate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://paved_road:paved_road@localhost:5432/paved_road_dev?schema=public}\" prisma validate --config prisma.config.ts",
    "prisma:migrate:dev": "DATABASE_URL=\"${DATABASE_URL:-postgresql://paved_road:paved_road@localhost:5432/paved_road_dev?schema=public}\" prisma migrate dev --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:seed": "DATABASE_URL=\"${DATABASE_URL:-postgresql://paved_road:paved_road@localhost:5432/paved_road_dev?schema=public}\" tsx prisma/seed.ts",
    "db:reset": "DATABASE_URL=\"${DATABASE_URL:-postgresql://paved_road:paved_road@localhost:5432/paved_road_dev?schema=public}\" prisma migrate reset --config prisma.config.ts --force && pnpm db:seed",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "latest"
  },
  "devDependencies": {
    "prisma": "latest",
    "tsx": "latest"
  }
}
