generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  cognitoSub String   @unique
  email      String?
  notes      Note[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum NoteUrgency {
  URGENT
  CAN_WAIT
  ANYTIME
}

model Note {
  id        String      @id @default(cuid())
  userId    String
  title     String
  content   String?
  urgency   NoteUrgency @default(CAN_WAIT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
